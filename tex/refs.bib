@article{COHEN1999,
title = {Galois Groups of Trinomials},
journal = {Journal of Algebra},
volume = {222},
number = {2},
pages = {561-573},
year = {1999},
issn = {0021-8693},
doi = {https://doi.org/10.1006/jabr.1999.8033},
url = {https://www.sciencedirect.com/science/article/pii/S002186939998033X},
author = {S.D Cohen and A Movahhedi and A Salinier},
abstract = {Galois groups of irreducible trinomials Xn+aXs+b∈Z[X] are investigated assuming the classification of finite simple groups. We show that under some simple yet general hypotheses bearing on the integers n, s, a and b only very specific groups can occur. For instance, if the two integers nb and as(n−s) are coprime and if s is a prime number, then already the Galois group of f(X) is either the alternating group An or the symmetric group Sn. This significantly extends work of Osada.}
}

