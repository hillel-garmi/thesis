@article{SelmerIrreducibility1956,
 ISSN = {00255521, 19031807},
 URL = {http://www.jstor.org/stable/24490297},
 abstract = {Through a study of certain generalized continued fractions, the author was led to the question of irreducibility of the trinomials f1(x) = xn – x – 1, f2(x) = xn + x + 1. These polynomials have extremely small discriminants, and a very regular distribution of zeros in the complex plane. By studying a certain symmetric function of these zeros, it is shown (Theorem 1) that f1(x) is irreducible for all n, while f2(x) is irreducible for n ≢ 2 (mod 3), but has a factor x2 + x + 1 for n ≡ 2 (mod 3); in the latter case, the second factor of f2(x) is irreducible. More generally, the trinomials F(x) = xn ± xm ± 1 (m < n) are considered, and certain limits are established for the number of irreducible factors and for the degree of each factor (Theorem 3). To examine the irreducibility of the polynomials F(x), a primality criterion of Pólya and Szegö is applied and extended. Some irreducibility criteria for polynomials of the type f(x2) and f(x3) are also introduced. In particular, f(x2) is irreducible if f(x) is an irreducible trinomial satisfying certain conditions (Theorem 4).},
 author = {ERNST S. SELMER},
 journal = {Mathematica Scandinavica},
 number = {2},
 pages = {287--302},
 publisher = {Mathematica Scandinavica},
 title = {ON THE IRREDUCIBILITY OF CERTAIN TRINOMIALS},
 urldate = {2026-03-20},
 volume = {4},
 year = {1956}
}

