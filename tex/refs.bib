@article{MARTIN2004213,
title = {The Galois group of $x^n - x^{n-1} - \cdots - x - 1$},
journal = {Journal of Pure and Applied Algebra},
volume = {190},
number = {1},
pages = {213-223},
year = {2004},
issn = {0022-4049},
doi = {https://doi.org/10.1016/j.jpaa.2003.10.028},
url = {https://www.sciencedirect.com/science/article/pii/S0022404903002457},
author = {Paulo A Martin},
abstract = {In this paper we prove that if n is an even integer or a prime number, then the Galois group of $x^n - x^{n-1} - \cdots - x - 1$ is the symmetric group $S_n$. This polynomial family arises quite naturally from a kind of generalized Fibonacci sequence. In order to prove our result for n=p prime, we had to prove that $x^n - x^{n-1} - \cdots - x - 1$ is irreducible in $F_p[x]$, which seems to be a result of independent interest.}
}

